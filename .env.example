# ── Payments (Stripe) ──────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys.
# Use test keys first; swap to live keys to go live.
# Publishable key (pk_…) is used by the browser to render the card fields.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_…) is server-only.
STRIPE_SECRET_KEY=
# Developers → Webhooks → add endpoint https://your-site/api/payments/webhook
# (event: payment_intent.succeeded) → copy its Signing secret (whsec_…).
STRIPE_WEBHOOK_SECRET=

# ── Order emails (Resend) ──────────────────────────────────────────────
# https://resend.com/api-keys
# Sandbox mode (no verified domain) can only send FROM onboarding@resend.dev
# and only TO the Resend account owner's own email. Verify a domain at
# resend.com/domains to lift both restrictions.
RESEND_API_KEY=
ORDER_EMAIL_FROM="beBeauty DIY <onboarding@resend.dev>"
ORDER_EMAIL_TO=oleheste.w1@gmail.com

# ── Site URL ───────────────────────────────────────────────────────────
# Public base URL, used by the client to build the Stripe return URL.
SITE_URL=https://bebeauty-diy-ee.netlify.app
