# ── Payments (Stripe) ──────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys.
# Use test keys first; swap to live keys to go live.
# Publishable key (pk_…) is used by the browser to render the card fields.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_…) is server-only.
STRIPE_SECRET_KEY=
# Developers → Webhooks → add endpoint https://your-site/api/payments/webhook
# (event: payment_intent.succeeded) → copy its Signing secret (whsec_…).
STRIPE_WEBHOOK_SECRET=

# ── Order emails (Resend) ──────────────────────────────────────────────
# https://resend.com/api-keys
# The "from" address must be on a domain verified at resend.com/domains —
# sandbox addresses like onboarding@resend.dev can only email the account
# owner's own inbox and will 403 for every real customer/order address.
RESEND_API_KEY=
ORDER_EMAIL_FROM="beBeauty DIY <tellimused@bebeauty.ee>"
# Comma-separate multiple addresses to notify more than one owner inbox.
ORDER_EMAIL_TO=oleheste12@gmail.com,iluinfo1@gmail.com

# ── Site URL ───────────────────────────────────────────────────────────
# Public base URL, used by the client to build the Stripe return URL.
SITE_URL=https://bebeauty-diy-ee.netlify.app

# ── Orders dashboard (/dashboard) ──────────────────────────────────────
# Single admin login — set your own username/password.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
